		description "Evidence Solution (Verification Activity): Report generation with Unit Tests or Equivalent"
		rationale "Allows quality monitoring in an industrial environment (SIL/HIL)"
		value predicate #MIC_Properties::VerificationValue >= coverage
		category Fidelity.ModelVerification
		see goal AEBSystemGoals.goalgeneral2	
	]
	
	requirement R7Verification2:"VDM-DEV-VERIF-02"[
		description "The model must be compatible with SIL code generation "
		description "Evidence Solution (Verification Activity): Code generated without error, Correlation Study"
		rationale "Ensures that the model is verifiable in SIL/HIL simulation later"
		category Fidelity.ModelVerification
		see goal AEBSystemGoals.goalgeneral2	
	]
	
	requirement R8Maturity:"VDM-DEV-MAT-01"[
		val maturity = 3
		description "The model must have a prototype, documented version history and comments"
		description "Evidence Solution (Verification Activity): Presence of a Git or other history tracking"
		rationale "Facilitates maintenance and certification and maturity estimation"
		value predicate #MIC_Properties::MaturityValue == maturity
		category Fidelity.Maturity
		see goal AEBSystemGoals.goalgeneral3		
	]
	
	
	
	requirement RPerformaceSimuTime: "VDM-DEV-PERF-01"[
		val simuTime = 250 ms
		description "The model should be executed during the defined runTime"
		description "Evidence Solution (Verification Activity): Measurement of simulation time on a standard scenario"
		rationale "Allows you to quickly test several concepts with few resources"
		value predicate #SimultionParametres::SimulationTime <= simuTime
		category Simulation.SimulatorCompatibility
		see goal AEBSystemGoals.g1 
