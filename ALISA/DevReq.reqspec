		rationale " To stop the vehicle if TTC is equal to MinTTC" 
		category  Fidelity.FunctionsCoverage
		see goal AEBSystemGoals.g5
	]
	
	requirement R5Validity:"VDM-DEV-VAL-01"[
		val ExpectedConcordance = 70.0 //%
		description "The model must be validated under AEB operational conditions in the target context"
		description "Evidence Solution (Verification Activity): Validation against EuroNCAP or similar scenarios"
		rationale "Ensure results are relevant in the target context"
		value predicate  #MIC_Properties::ValidityValue >= ExpectedConcordance 
		category Validation.Validity
		see goal AEBSystemGoals.goalgeneral1	
	]
	
	requirement R6Verification:"VDM-DEV-VERIF-01"[
		val coverage = 80.0 //%
